    "@types/node": "^25.3.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.3",
    "eslint-config-love": "^151.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
