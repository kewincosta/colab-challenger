{
  "name": "colab-challenger",
  "version": "1.0.0",
  "private": true,
  "description": "Colab Challenger Monorepo",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "sh scripts/dev.sh",
    "api": "npm run start -w @colab-challenger/api",
    "api:dev": "npm run start -w @colab-challenger/api",
    "api:build": "npm run build -w @colab-challenger/api",
    "api:test": "npm run test -w @colab-challenger/api",
    "api:lint": "npm run lint -w @colab-challenger/api",
    "web:dev": "npm run dev -w @colab-challenger/web",
    "web:build": "npm run build -w @colab-challenger/web",
    "web:lint": "npm run lint -w @colab-challenger/web",
    "test": "npm run test -w @colab-challenger/api",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
